<Window x:Class="DracoUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:local="clr-namespace:DracoUI"
        KeyDown="Window_KeyDown"
        mc:Ignorable="d"
        Title="Draco" Height="450" Width="800"
        Icon="/Resources/DracoIcon.ico"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent">
    <Window.Resources>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TabPanel Grid.Row="0" IsItemsHost="True" Background="Black"/>
                            <Border Grid.Row="1" Background="{TemplateBinding Background}">
                                <ContentPresenter ContentSource="SelectedContent"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="FontFamily" Value="/Resources/#Orbitron"/>
            <Setter Property="FontSize" Value="11"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" 
                        Background="Transparent" 
                        Padding="15,8" 
                        Margin="0,0,2,0"
                        BorderBrush="Transparent"
                        BorderThickness="0,0,0,2">

                            <ContentPresenter x:Name="Content"
                                    ContentSource="Header"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#1A1A1A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="OrangeRed"/>
                                <Setter TargetName="TabBorder" Property="Background" Value="#0F0F0F"/>
                                <Setter Property="Foreground" Value="OrangeRed"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#0D0D0D"/>
            <Setter Property="Foreground" Value="OrangeRed"/>
            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder" 
                            Background="{TemplateBinding Background}" 
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TreeViewItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <Border x:Name="SelectionBorder" Background="Transparent">
                                <ContentPresenter x:Name="PART_Header" 
                                        ContentSource="Header" 
                                        HorizontalAlignment="Left" 
                                        VerticalAlignment="Center"/>
                            </Border>

                            <ItemsPresenter x:Name="ItemsHost" 
                                    Grid.Row="1" 
                                    Visibility="Collapsed" 
                                    Margin="18,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="SelectionBorder" Property="Background" Value="#222"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ScrollBarCanvas" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Focusable" Value="false"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Rectangle Fill="{TemplateBinding Background}" Height="{TemplateBinding Height}" Width="{TemplateBinding Width}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ScrollBarThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="rectangle" 
                        Background="#333" 
                        CornerRadius="3" 
                        Margin="1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="rectangle" Property="Background" Value="OrangeRed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#050505"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Bg" Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter Property="Width" Value="10"/>
                                <Setter Property="Height" Value="Auto"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Width" Value="Auto"/>
                                <Setter Property="Height" Value="10"/>
                                <Setter Property="VerticalAlignment" Value="Bottom"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ScrollContentPresenter Grid.Column="0" Grid.Row="0"/>

                            <ScrollBar x:Name="PART_VerticalScrollBar" Grid.Column="1" Grid.Row="0"
                               Orientation="Vertical"
                               Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                               Value="{TemplateBinding VerticalOffset}"
                               Maximum="{TemplateBinding ScrollableHeight}"
                               ViewportSize="{TemplateBinding ViewportHeight}"/>

                            <ScrollBar x:Name="PART_HorizontalScrollBar" Grid.Column="0" Grid.Row="1"
                               Orientation="Horizontal"
                               Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                               Value="{TemplateBinding HorizontalOffset}"
                               Maximum="{TemplateBinding ScrollableWidth}"
                               ViewportSize="{TemplateBinding ViewportWidth}"/>

                            <Rectangle Grid.Column="1" Grid.Row="1" Fill="#050505"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Background="#0D0D0D" BorderBrush="#333" BorderThickness="1.5">
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=WindowState}" Value="Maximized">
                        <Setter Property="Padding" Value="8"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=WindowState}" Value="Normal">
                        <Setter Property="Padding" Value="0"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#000000">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,0,0,0" Height="40">
                    <Image Source="/Resources/DracoIcon.png"  Width="61" Height="28" RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock FontSize="16" Text="Draco" Foreground="GhostWhite" Padding="0, 9.5, 0, 0" FontFamily="Calibri" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,5,10,0">
                    <Button Content="_" Width="30" Height="25" Padding="0,0,0,8" Background="Transparent" Foreground="OrangeRed" Click="MinimizeButton_Click" MouseEnter="UtilityButtonHover" MouseLeave="UtilityButtonLeave"/>
                    <Button Content="▢" Width="30" Height="25" Background="Transparent" Foreground="OrangeRed" Click="MaximizeButton_Click" MouseEnter="UtilityButtonHover" MouseLeave="UtilityButtonLeave"/>
                    <Button Content="X" Width="30" Height="25" Background="Transparent" Foreground="OrangeRed" Click="ExitButton_Click" MouseEnter="UtilityButtonHover" MouseLeave="UtilityButtonLeave"/>
                </StackPanel>
                <Border BorderBrush="LightCoral" BorderThickness="0, 0, 0, 1" Opacity="0.5"/>
            </Grid>

            <Grid Grid.Row="1">

                <Grid x:Name="HomeView" Visibility="Visible">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="344*"/>
                        <ColumnDefinition Width="153*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="40,0,40,0">
                        <TextBlock Text="DRACO" Foreground="OrangeRed" FontSize="36" HorizontalAlignment="Center" FontWeight="Bold" FontFamily="/Resources/#DragonForcE" Margin="0,0,0,20"/>
                        <Button Content="OPEN  FILE" FontSize="20" Padding="15,10" Margin="0,5" FontFamily="/Resources/#DragonForcE" MouseEnter="MenuButtonHover" MouseLeave="MenuButtonLeave"
                                Click="HomeOpenFile_Click"/>
                        <Button Content="OPEN  FOLDER" FontSize ="20" Padding="15,10" Margin="0,5" FontFamily="/Resources/#DragonForcE" MouseEnter="MenuButtonHover" MouseLeave="MenuButtonLeave"
                                Click="HomeOpenFolder_Click"/>
                    </StackPanel>

                    <Border Grid.Column="1" Background="#050505" CornerRadius="5" Margin="20,20,20,20" BorderBrush="#222" BorderThickness="1" Grid.ColumnSpan="2">
                        <StackPanel VerticalAlignment="Center" Margin="20">
                            <TextBlock Text="[ DRACO'S ORACLE ]" Foreground="Gray" FontSize="10" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="AITipText" Text="Waiting for Ollama AI..." Foreground="LightGray" TextWrapping="Wrap" FontSize="16" FontStyle="Italic" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="EditorView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="150"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#0D0D0D">
                        <Image Source="/Resources/FileTab.png" Width="70" Height="47" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <Button x:Name="FileButton" Content="File" Padding="10,2" Background="#0D0D0D" Foreground="OrangeRed" FontFamily="/Resources/#Orbitron"
                                MouseEnter="MenuButtonHover" MouseLeave="MenuButtonLeave" Click="FileButtonClick"/>
                        <Popup x:Name="FileOptions" PlacementTarget="{Binding ElementName=FileButton}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True">
                            <Border Background="#1A1A1A" BorderBrush="#333" BorderThickness="1" Padding="2">
                                <StackPanel>
                                    <Button HorizontalContentAlignment="Stretch" Background="Transparent" BorderThickness="0" Padding="10,5" 
                                            MouseEnter="PopupButtonHover" MouseLeave="PopupButtonLeave" Click="NewFile_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="New File" Foreground="OrangeRed" HorizontalAlignment="Left" FontFamily="/Resources/#Orbitron"/>
                                            <TextBlock Grid.Column="1" Text="Ctrl + N" Foreground="Gray" HorizontalAlignment="Right" Margin="30,0,0,0" FontFamily="/Resources/#Orbitron"/>
                                        </Grid>
                                    </Button>
                                    <Button HorizontalContentAlignment="Stretch" Background="Transparent" BorderThickness="0" Padding="10,5" 
                                            MouseEnter="PopupButtonHover" MouseLeave="PopupButtonLeave" Click="HomeOpenFile_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Open File..." Foreground="OrangeRed" HorizontalAlignment="Left" FontFamily="/Resources/#Orbitron"/>
                                            <TextBlock Grid.Column="1" Text="Ctrl + O" Foreground="Gray" HorizontalAlignment="Right" Margin="30,0,0,0" FontFamily="/Resources/#Orbitron"/>
                                        </Grid>
                                    </Button>
                                    <Button HorizontalContentAlignment="Stretch" Background="Transparent" BorderThickness="0" Padding="10,5" 
                                            MouseEnter="PopupButtonHover" MouseLeave="PopupButtonLeave" Click="HomeOpenFolder_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Open Folder..." Foreground="OrangeRed" HorizontalAlignment="Left" FontFamily="/Resources/#Orbitron"/>
                                            <TextBlock Grid.Column="1" Text="Ctrl + Shift + O" Foreground="Gray" HorizontalAlignment="Right" Margin="30,0,0,0" FontFamily="/Resources/#Orbitron"/>
                                        </Grid>
                                    </Button>
                                    <Button HorizontalContentAlignment="Stretch" Background="Transparent" BorderThickness="0" Padding="10,5" 
                                            MouseEnter="PopupButtonHover" MouseLeave="PopupButtonLeave" Click="SaveFile_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Save" Foreground="OrangeRed" HorizontalAlignment="Left" FontFamily="/Resources/#Orbitron"/>
                                            <TextBlock Grid.Column="1" Text="Ctrl + S" Foreground="Gray" HorizontalAlignment="Right" Margin="30,0,0,0" FontFamily="/Resources/#Orbitron"/>
                                        </Grid>
                                    </Button>
                                    <Button HorizontalContentAlignment="Stretch" Background="Transparent" BorderThickness="0" Padding="10,5" 
                                            MouseEnter="PopupButtonHover" MouseLeave="PopupButtonLeave" Click="SaveFileAs_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Save As..." Foreground="OrangeRed" HorizontalAlignment="Left" FontFamily="/Resources/#Orbitron"/>
                                            <TextBlock Grid.Column="1" Text="Ctrl + Shift + S" Foreground="Gray" HorizontalAlignment="Right" Margin="30,0,0,0" FontFamily="/Resources/#Orbitron"/>
                                        </Grid>
                                    </Button>
                                    <Button HorizontalContentAlignment="Stretch" Background="Transparent" BorderThickness="0" Padding="10,5" 
                                            MouseEnter="PopupButtonHover" MouseLeave="PopupButtonLeave" Click="CloseEditor_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Close Editor" Foreground="OrangeRed" HorizontalAlignment="Left" FontFamily="/Resources/#Orbitron"/>
                                            <TextBlock Grid.Column="1" Text="Ctrl + W" Foreground="Gray" HorizontalAlignment="Right" Margin="30,0,0,0" FontFamily="/Resources/#Orbitron"/>
                                        </Grid>
                                    </Button>
                                    <Button HorizontalContentAlignment="Stretch" Background="Transparent" BorderThickness="0" Padding="10,5" 
                                            MouseEnter="PopupButtonHover" MouseLeave="PopupButtonLeave" Click="ExitApp_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Exit" Foreground="OrangeRed" HorizontalAlignment="Left" FontFamily="/Resources/#Orbitron"/>
                                            <TextBlock Grid.Column="1" Text="Alt + F4" Foreground="Gray" HorizontalAlignment="Right" Margin="30,0,0,0" FontFamily="/Resources/#Orbitron"/>
                                        </Grid>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Popup>
                        <Image Source="/Resources/BuildTab.png" Width="61" Height="40" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <Button Content="Build" Padding="10,2" Background="#0D0D0D" Foreground="OrangeRed" FontFamily="/Resources/#Orbitron"
                                MouseEnter="MenuButtonHover" MouseLeave="MenuButtonLeave" Click="BuildButton_Click"/>
                        <Image Source="/Resources/RunTab.png" Width="61" Height="40" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <Button Content="Run" Padding="10,2" Background="#0D0D0D" Foreground="OrangeRed" FontFamily="/Resources/#Orbitron"
                                MouseEnter="MenuButtonHover" MouseLeave="MenuButtonLeave" Click="RunButton_Click"/>
                        <Image Source="/Resources/FangTab.png" Width="61" Height="40" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <Button Content="Fang" Padding="10,2" Background="#0D0D0D" Foreground="OrangeRed" FontFamily="/Resources/#Orbitron"
                                MouseEnter="MenuButtonHover" MouseLeave="MenuButtonLeave" Click="FangButton_Click"/>
                    </StackPanel>
                    <Border Grid.Row="0" BorderThickness="0, 0, 0, 1" BorderBrush="LightCoral" Opacity="0.5"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#0F0F0F" BorderBrush="#333" BorderThickness="0,0,1,0">
                            <TreeView x:Name="ExplorerTab"  ItemsSource="{Binding ExplorerData}" Background="Transparent" 
                            BorderThickness="0" SelectedItemChanged="ChangeCodeDisplayed">
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate DataType="{x:Type local:ExplorerItem}" 
                                  ItemsSource="{Binding Items}">
                                        <StackPanel Orientation="Horizontal" Margin="2">
                                            <TextBlock VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,5,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value=">"/>
                                                        <Setter Property="Foreground" Value="OrangeRed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                                <Setter Property="Text" Value="◢"/>
                                                                <Setter Property="Foreground" Value="Gray"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Title}" Foreground="LightGray"  VerticalAlignment="Center"
                                           FontFamily="./Resources/#Iosevka" Margin="0, 2, 0 ,0"/>
                                        </StackPanel>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </Border>
                        <avalonEdit:TextEditor Grid.Column="1" x:Name="CodeEditor" Background="#0D0D0D" Foreground ="#CCCCCC" FontSize="14"
                                               BorderThickness="0" Padding="10" FontFamily="/Resources/#Iosevka"
                                               HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                               ShowLineNumbers="True" LineNumbersForeground="#666666"/>
                    </Grid>
                    <GridSplitter Grid.Row="2" Height="3" HorizontalAlignment="Stretch" 
                      Background="#222" VerticalAlignment="Center" Margin="0,2"/>
                    <Border Grid.Row="3" Background="#0A0A0A" BorderBrush="#333" BorderThickness="0,1,0,0">
                        <TabControl x:Name="OutputTabs" Background="Transparent" BorderThickness="0">
                            <TabItem Header="BUILD" Foreground="GhostWhite">
                                <TextBox x:Name="BuildOutput" Background="Black" Foreground="#D8A0A0" 
                             BorderThickness="0" IsReadOnly="True" FontFamily="/Resources/#Iosevka" 
                             Padding="10" Text="Build output will appear here..." VerticalScrollBarVisibility="Auto"
                             PreviewMouseWheel="Output_PreviewMouseWheel"/>
                            </TabItem>

                            <TabItem Header="TERMINAL" Foreground="GhostWhite">
                                <TextBox x:Name="TerminalOutput" Background="Black" Foreground="GhostWhite" 
                             BorderThickness="0" IsReadOnly="True" FontFamily="/Resources/#Iosevka" 
                             Padding="10" Text="Program execution output..." VerticalScrollBarVisibility="Auto"/>
                            </TabItem>
                        </TabControl>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>