<?xml version="1.0"?>
<SyntaxDefinition name="CPP" xmlns="http://icsharpcode.net/sharpdevelop/syntaxdefinition/2008">
    
    <Color name="Comment" foreground="#7A7A7A" fontStyle="italic" />
    <Color name="String" foreground="#D28445"/>
    <Color name="ControlKeyword" foreground="#C54A4A" fontWeight="bold"/>
	<Color name="DirectiveKeyword" foreground="#D8A0A0"/>
	<Color name="TypeKeyword" foreground ="#FF8559"/>
    <Color name="Number" foreground="#FDFD96"/>
	<Color name="STL" foreground="#DC143C"/>
	<Color name="Literals" foreground="#B7410E"/>
    <RuleSet>
        
        <Span color="Comment" begin="//" />
        
        <Span color="String">
            <Begin>"</Begin>
            <End>"</End>
            <RuleSet>
                <Span begin="\\" end="." /> </RuleSet>
        </Span>
		 <Span color="String">
            <Begin>'</Begin>
            <End>'</End>
            <RuleSet>
                <Span begin="\\" end="." /> </RuleSet>
        </Span>
		<Span color="Comment" multiline ="true">
			<Begin>/\*</Begin>
			<End>\*/</End>
	    </Span>
        <Rule color="Number">
            \b0[xX][0-9a-fA-F]+|(\b\d+(\.[0-9]+)?|\.[0-9]+)([eE][+-]?[0-9]+)?
        </Rule>
		<Keywords color="ControlKeyword">
            <Word>if</Word>
            <Word>else</Word>
            <Word>switch</Word>
            <Word>case</Word>
            <Word>default</Word>
            <Word>for</Word>
            <Word>while</Word>
            <Word>do</Word>
            <Word>return</Word>
            <Word>break</Word>
            <Word>continue</Word>
            <Word>goto</Word>
            <Word>try</Word>
            <Word>catch</Word>
            <Word>throw</Word>
            <Word>and</Word>
            <Word>or</Word>
            <Word>not</Word>
            <Word>xor</Word>
        </Keywords>
		<Keywords color="Literals">
            <Word>true</Word>
            <Word>false</Word>
            <Word>nullptr</Word>
            <Word>this</Word>
        </Keywords>
        <Keywords color="DirectiveKeyword">
			<Word>include</Word>
            <Word>using</Word>
            <Word>namespace</Word>
            <Word>template</Word>
            <Word>typedef</Word>
		    <Word>define</Word>
		    <Word>typedef</Word>
		    <Word>undef</Word>
		    <Word>ifdef</Word>
		    <Word>ifndef</Word>
		    <Word>endif</Word>
		    <Word>elif</Word>
		    <Word>pragma</Word>
			<Word>static_cast</Word>
			<Word>dynamic_cast</Word>
			<Word>reinterpret_cast</Word>
		    <Word>const_cast</Word>
        </Keywords>
        <Keywords color="TypeKeyword">
            <Word>int</Word>
            <Word>void</Word>
            <Word>double</Word>
            <Word>float</Word>
            <Word>char</Word>
			<Word>auto</Word>
		    <Word>struct</Word>
            <Word>class</Word>
            <Word>union</Word>
            <Word>enum</Word>
            <Word>long</Word>
            <Word>short</Word>
            <Word>signed</Word>
            <Word>unsigned</Word>
            <Word>const</Word>
            <Word>static</Word>
            <Word>volatile</Word>
            <Word>extern</Word>
            <Word>inline</Word>
            <Word>virtual</Word>
            <Word>override</Word>
            <Word>final</Word>
            <Word>explicit</Word>
            <Word>mutable</Word>
            <Word>public</Word>
            <Word>private</Word>
            <Word>protected</Word>
            <Word>friend</Word>
		    <Word>size_t</Word>
			<Word>int8_t</Word>
			<Word>int16_t</Word>
			<Word>int32_t</Word>
			<Word>int64_t</Word>
			<Word>uint8_t</Word>
			<Word>uint16_t</Word>
			<Word>uint32_t</Word>
			<Word>uint64_t</Word>
        </Keywords>
	    <Keywords color="STL">
            <Word>std</Word>
            <Word>bits</Word>
            <Word>stdc++</Word>
            <Word>h</Word>
            <Word>iostream</Word>
            <Word>fstream</Word>
