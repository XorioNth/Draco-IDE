            <Word>unordered_multiset</Word>
            <Word>pair</Word>
            <Word>tuple</Word>
            <Word>array</Word>
            <Word>bitset</Word>
            <Word>forward_list</Word>
            <Word>push_back</Word>
            <Word>pop_back</Word>
            <Word>push</Word>
            <Word>pop</Word>
            <Word>top</Word>
            <Word>front</Word>
            <Word>back</Word>
            <Word>insert</Word>
            <Word>erase</Word>
            <Word>clear</Word>
            <Word>size</Word>
            <Word>empty</Word>
            <Word>begin</Word>
            <Word>end</Word>
            <Word>rbegin</Word>
            <Word>rend</Word>
            <Word>find</Word>
            <Word>count</Word>
            <Word>lower_bound</Word>
            <Word>upper_bound</Word>
            <Word>emplace_back</Word>
            <Word>assign</Word>
            <Word>at</Word>
            <Word>swap</Word>
            <Word>algorithm</Word>
            <Word>sort</Word>
            <Word>stable_sort</Word>
            <Word>reverse</Word>
            <Word>max</Word>
            <Word>min</Word>
            <Word>abs</Word>
            <Word>sqrt</Word>
            <Word>pow</Word>
            <Word>min_element</Word>
            <Word>max_element</Word>
            <Word>next_permutation</Word>
            <Word>prev_permutation</Word>
            <Word>cmath</Word>
            <Word>limits</Word>
            <Word>numeric</Word>
            <Word>functional</Word>
            <Word>shared_ptr</Word>
            <Word>unique_ptr</Word>
            <Word>weak_ptr</Word>
            <Word>make_shared</Word>
            <Word>make_unique</Word>
            <Word>nullptr</Word>
		    <Word>remove</Word>
            <Word>remove_if</Word>
            <Word>replace</Word>
            <Word>unique</Word>
            <Word>fill</Word>
            <Word>generate</Word>
            <Word>transform</Word>
            <Word>accumulate</Word>
