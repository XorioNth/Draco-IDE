		    <Word>concept</Word>
            <Word>requires</Word>
            <Word>integral</Word>
            <Word>floating_point</Word>
            <Word>convertible_to</Word>
            <Word>derived_from</Word>
            <Word>ranges</Word>
            <Word>views</Word>
            <Word>filter</Word>
            <Word>transform</Word>
            <Word>take</Word>
